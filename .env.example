# ==============================================
# AIGC-MAS Production Environment Configuration
# ==============================================
# 
# CRITICAL: All variables marked with [REQUIRED] must be configured 
# before production deployment. The application will fail to start 
# if these variables are missing or invalid.
#
# For Supabase setup, follow these steps:
# 1. Create a Supabase project at https://supabase.com
# 2. Get the database password from Project Settings > Database
# 3. Get the Service Role Key from Project Settings > API
# 4. Get the Anon Key from Project Settings > API
# ==============================================

# [REQUIRED] Database Configuration
# Project: MAS | Region: ap-southeast-1
DATABASE_URL="postgresql://postgres.tuutaixcohouimlzuivg:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.tuutaixcohouimlzuivg:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# [REQUIRED] Supabase Configuration
SUPABASE_URL="https://tuutaixcohouimlzuivg.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# Client-side Supabase (Required for frontend)
VITE_SUPABASE_URL="https://tuutaixcohouimlzuivg.supabase.co"
VITE_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# ==============================================
# Optional Configuration
# ==============================================

# Payment System (Alipay)
# Leave empty for mock mode during development
ALIPAY_APP_ID=""
ALIPAY_APP_PRIVATE_KEY=""
ALIPAY_ALIPAY_PUBLIC_KEY=""

# AI Provider Configuration
# Options: mock (default), openai, claude
AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_MODEL="gpt-4o"

# Application Settings
PORT=3000
NODE_ENV=production
