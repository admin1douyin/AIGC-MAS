# ==============================================
# AIGC-MAS Server Environment Configuration
# ==============================================
# 
# CRITICAL: All variables marked with [REQUIRED] must be configured 
# before production deployment. The application will fail to start 
# if these variables are missing or invalid.
#
# Copy this file to .env.production for deployment
# ==============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# [REQUIRED] Supabase PostgreSQL Database
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]/postgres
# Get from Supabase Dashboard > Project Settings > Database
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# [REQUIRED] Supabase Auth & Admin
# Get from Supabase Dashboard > Project Settings > API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# ==============================================
# Optional: Payment & AI Configuration
# ==============================================

# Payment - Leave empty for mock mode
ALIPAY_APP_ID=""
ALIPAY_APP_PRIVATE_KEY=""
ALIPAY_ALIPAY_PUBLIC_KEY=""

# AI Provider - mock by default
AI_PROVIDER="mock"  # Options: mock, openai, claude
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_MODEL="gpt-4o"  # or claude-3-5-sonnet-20241022

# ==============================================
# Video Generation - Seedance
# ==============================================
SEEDANCE_API_KEY=""
SEEDANCE_BASE_URL="https://api.seedance.com/v1"
SEEDANCE_DEFAULT_MODEL="seedance-2.5"  # seedance-2.0 or seedance-2.5
