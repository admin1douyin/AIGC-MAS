# Server
PORT=3001
NODE_ENV=development

# Supabase PostgreSQL Database
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.tuutaixcohouimlzuivg.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.tuutaixcohouimlzuivg.supabase.co:5432/postgres"

# Supabase Auth
SUPABASE_URL="https://tuutaixcohouimlzuivg.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Alipay Configuration (for payment system)
# Leave empty for mock mode during development
ALIPAY_APP_ID=""
ALIPAY_APP_PRIVATE_KEY=""
ALIPAY_ALIPAY_PUBLIC_KEY=""

# AI Configuration (optional - uses mock mode by default)
# Set AI_PROVIDER to 'openai' or 'claude' and provide API key
AI_PROVIDER="mock"  # Options: mock, openai, claude
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_MODEL="gpt-4o"  # Model to use (gpt-4o, claude-3-5-sonnet, etc.)
