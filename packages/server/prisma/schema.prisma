generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  role          String    @default("user")
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[] @relation("ProjectOwner")
}

model Project {
  id              String   @id @default(uuid())
  name            String
  type            String
  status          String   @default("draft")
  description     String?
  brief           String?
  progress        Int      @default(0)
  ownerId         String
  owner           User     @relation("ProjectOwner", fields: [ownerId], references: [id])
  tags            String?
  estimatedDuration Int?
  actualDuration  Int?
  budget          Float?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  agents          Agent[]
  tasks           AgentTask[]
  messages        AgentMessage[]
  scripts         VideoScript[]
  storyboards     Storyboard[]
  assets          VideoAsset[]
  finalVideos     FinalVideo[]
  shortDrama      ShortDramaProject?
  corporateVideo  CorporateVideoProject?
  tourismPromo    TourismPromoProject?
}

model Agent {
  id              String   @id @default(uuid())
  name            String
  role            String
  status          String   @default("idle")
  description     String?
  capabilities    String?
  currentTaskId   String?
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tasks           AgentTask[] @relation("AgentTasks")
  sentMessages    AgentMessage[] @relation("SentMessages")
  receivedMessages AgentMessage[] @relation("ReceivedMessages")
}

model AgentTask {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  agentId         String?
  agent           Agent?   @relation("AgentTasks", fields: [agentId], references: [id])
  agentRole       String
  title           String
  description     String?
  status          String   @default("pending")
  priority        String   @default("medium")
  inputData       String?
  outputData      String?
  dependsOn       String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  messages        AgentMessage[]
}

model AgentMessage {
  id              String   @id @default(uuid())
  fromAgentId     String
  fromAgent       Agent    @relation("SentMessages", fields: [fromAgentId], references: [id])
  toAgentId       String?
  toAgent         Agent?   @relation("ReceivedMessages", fields: [toAgentId], references: [id])
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  taskId          String?
  task            AgentTask? @relation(fields: [taskId], references: [id])
  content         String
  messageType     String
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model VideoScript {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  title           String
  scenes          String?
  totalDuration   Int      @default(0)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  storyboards     Storyboard[]
}

model Storyboard {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  scriptId        String
  script          VideoScript @relation(fields: [scriptId], references: [id])
  frames          String?
  createdAt       DateTime @default(now())
}

model VideoAsset {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  type            String
  name            String
  url             String
  duration        Int?
  metadata        String?
  createdAt       DateTime @default(now())
}

model FinalVideo {
  id              String   @id @default(uuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  title           String
  url             String
  thumbnailUrl    String?
  duration        Int
  resolution      String
  format          String
  size            Int
  version         Int      @default(1)
  createdAt       DateTime @default(now())
}

model ShortDramaProject {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id])
  genre           String?
  episodeCount    Int      @default(1)
  episodeDuration Int?
  mainCharacters  String?
  plotSummary     String?
  tone            String?
  targetPlatform  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CorporateVideoProject {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id])
  companyName     String?
  industry        String?
  videoType       String?
  brandGuidelines String?
  keySellingPoints String?
  callToAction    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TourismPromoProject {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id])
  location        String?
  attractions     String?
  culturalHighlights String?
  targetTravelers String?
  season          String?
  durationDays    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
